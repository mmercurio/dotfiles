" --- from "mastering VIM"
filetype plugin indent on " Enable file type based options.
set nocompatible          " Don't run in backwards compatible mode.
                          "  - This is the default in all recent versions of
                          "    VIM. Unnecessary?
set autoindent            " Respect indentation when starting new line.
set expandtab             " Expand tabs to spaces. Essential in Python.
set tabstop=4             " Number of spaces tab is counted for.
set shiftwidth=4          " Number of spaces to use for autoindent.
set shiftround            " Indent round multiple of shiftwidth
set backspace=2           " Fix backspace behavior on most terminals.

" --- from "mastering VIM"


let mapleader = " "
set autoindent
set smartindent
set cursorline
set cursorcolumn
" colorcolumns
let g:color_cols = "76,120"
" toggle colorcolumn on/off with <leader>cc
"" nnoremap <silent> <F5> :let &colorcolumn = (&colorcolumn ==# g:color_cols) ? '' : g:color_cols<CR>
nnoremap <silent> <leader>cc :let &colorcolumn = (&colorcolumn ==# g:color_cols) ? '' : g:color_cols<CR>

set number
"set numberwidth=5
set ruler

set incsearch
set hlsearch
" clear search highlights
nnoremap <leader>nh :nohl<CR>

" i = mouse reporting for insert mode
" set mouse=i
" a = mouse reporting for all modes
set mouse=a

" selection is auto copied to system cliboard
" yank is using * (system clipboard)
" works well on macOS
" https://vimdoc.sourceforge.net/htmldoc/options.html#'clipboard'
set clipboard=autoselect,unnamed

filetype plugin indent on

" show existing tab with 4 spaces width
set tabstop=4
" when indenting with '>', use 4 spaces width
set shiftwidth=4
" On pressing tab, insert 4 spaces
set expandtab

syntax enable

" Needed for color scheems to work properly
" on some terminals on macOS (e.g., WezTerm)
set background=dark
set termguicolors

" Create highlight group for extra whitespace
"   https://vim.fandom.com/wiki/Highlight_unwanted_spaces
highlight ExtraWhitespace ctermbg=red guibg=red
autocmd ColorScheme * highlight ExtraWhitespace ctermbg=red guibg=red

" Show trailing whitespace:
" match ExtraWhitespace /\s\+$/
" Show trailing whitespace, except when typing at the end of a line:
match ExtraWhitespace /\s\+\%#\@<!$/

" Quickly remove trailing whitespace
" https://vim.fandom.com/wiki/Remove_unwanted_spaces
" https://vi.stackexchange.com/a/2285/35205
function! TrimWhitespace()
    let l:save = winsaveview()
    keeppatterns %s/\s\+$//e
    call winrestview(l:save)
endfunction
command! TrimWhitespace call TrimWhitespace()
nnoremap <F5> :call TrimWhitespace()<CR>
nnoremap <Leader>w :call TrimWhitespace()<CR>

" Switch off using :match

" vim-plug: https://github.com/junegunn/vim-plug
" Specify a directory for plugins
" - For Neovim: stdpath('data') . '/plugged'
" - Avoid using standard Vim directory names like 'plugin'

" Install vim-plug if not found
if empty(glob('~/.vim/autoload/plug.vim'))
  silent !curl -fLo ~/.vim/autoload/plug.vim --create-dirs
    \ https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
endif

" Run PlugInstall if there are missing plugins [Note, this may slow startup]
" https://github.com/junegunn/vim-plug/wiki/tips#automatic-installation-of-missing-plugins
autocmd VimEnter * if len(filter(values(g:plugs), '!isdirectory(v:val.dir)'))
  \| PlugInstall --sync | source $MYVIMRC
\| endif

call plug#begin('~/.vim/plugged')

Plug 'wojciechkepka/vim-github-dark'

" Initialize plugin system
call plug#end()

" Optional workaround to keep the colorscheme from setting a background:
"    https://vi.stackexchange.com/a/18221
" Disabled by default to preserve the colorscheme's current behavior:
" autocmd ColorScheme * highlight Normal ctermbg=NONE guibg=NONE

colorscheme ghdark

highlight ColorColumn ctermbg=238 guibg=#444444

" quickly exit insert mode with jk
imap jk <ESC>

" navigate panes with Ctrl + hjkl
" using autocmd because something is overwriting these
" mappings in new buffers. No clue why.
augroup WindowNavigation
    autocmd!
    autocmd BufWinEnter * nnoremap <C-h> <C-w><C-h>
    autocmd BufWinEnter * nnoremap <C-j> <C-w><C-j>
    autocmd BufWinEnter * nnoremap <C-k> <C-w><C-k>
    autocmd BufWinEnter * nnoremap <C-l> <C-w><C-l>
augroup END

set splitbelow
set splitright

" split virtcally and horizontally
nnoremap <leader>sv :vsplit
nnoremap <leader>sh :split
nnoremap <leader>se <C-w>=
nnoremap <leader>sx :close<CR>

" tabs
nnoremap <leader>to :tabnew<CR>
nnoremap <leader>tx :tabclose<CR>
nnoremap <leader>tn :tabn<CR>
nnoremap <leader>tp :tabp<CR>
nnoremap <leader>tf :tabnew %<CR>
